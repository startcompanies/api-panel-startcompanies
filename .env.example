# ============================================
# Configuración del Servidor
# ============================================
PORT=3000
MODE=DEV

# URL pública de esta API (sin barra final). Se usa p. ej. para el callback OAuth Zoho:
# {API_PUBLIC_URL}/orgTk/callback — debe coincidir con "Authorized Redirect URI" en Zoho.
API_PUBLIC_URL=http://localhost:3000

# URL pública del portal/panel (enlaces en correos: invitación, reset password, etc.)
FRONTEND_URL=http://localhost:4200

# CORS: orígenes extra del portal (white-label), separados por coma. En DEV ya están localhost:4200.
# TENANT_CORS_ORIGINS=http://localhost:4200,https://portal.taxsolution.com
# PLATFORM_HOSTS=startcompanies.io,localhost
# Host canónico al que el partner apunta su CNAME (documentación / soporte)
TENANT_DNS_CNAME=tenants.startcompanies.io

# Preview Open Graph (WhatsApp / redes): el portal nginx hace proxy a GET /public/tenant/preview
# usando el Host del dominio white-label. No requiere variables extra en el API.

# ============================================
# Configuración de Base de Datos PostgreSQL
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=startcompanies

# Opcional: PostgreSQL con TLS (p. ej. RDS). db:wipe-panel / db:wipe-panel:prod lo usan.
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Solo para npm run db:wipe-panel:prod -- --yes (evita borrar prod por error)
# PANEL_WIPE_ALLOW_IN_PRODUCTION=1

# ============================================
# Configuración de JWT
# ============================================
JWT_SECRET=tu_secret_jwt_super_seguro_aqui_cambiar_en_produccion

# Opcional: secreto dedicado para el hash del código OTP del login (si no se define, se usa JWT_SECRET)
# LOGIN_OTP_SECRET=

# ============================================
# Webhook Zoho CRM → Panel (actualizar Request stage/status/workdrive)
# ============================================
# Secreto compartido: enviarlo en header X-Zoho-Sync-Secret desde Workflow/Deluge
# POST /zoho-sync/webhooks/crm/request-stage-sync
ZOHOCRM_REQUEST_SYNC_WEBHOOK_SECRET=cambiar_por_un_secreto_largo_aleatorio

# OAuth Zoho CRM (tabla zoho_config / flujo orgTk): para subir adjuntos al Account tras sync,
# el refresh_token debe haberse generado con scope ZohoCRM.modules.attachments.ALL
# (además de permisos del módulo Accounts u otros que ya uses).

# Import Zoho → BD: filtrar por clientes-activos-panel.json / partners-panel.json (ver src/data/)
# ZOHO_IMPORT_CLIENT_ALLOWLIST_ENABLED=false

# Tras import Zoho, al crear usuario cliente o partner nuevo: email de bienvenida (requiere RESEND_API_KEY y RESEND_FROM_EMAIL).
# También escribe en log la plantilla de texto sugerida para WhatsApp (partners).
# ZOHO_SYNC_WELCOME_EMAILS_ENABLED=false

# ============================================
# Email (Resend)
# ============================================
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Start Companies <noreply@startcompanies.us>
# RESEND_REPLY_TO=facturacion@tudominio.com
# Misma marca que el remitente visible cuando no hay razón social de LLC en el perfil:
# EMAIL_PLATFORM_NAME=Start Companies
# Para menos spam: verifica el dominio del remitente en Resend (SPF/DKIM) y usa un FROM alineado con ese dominio.

# ============================================
# Configuración de AWS S3 (para almacenamiento de archivos)
# ============================================
AWS_ACCESS_KEY_ID=tu_aws_access_key_id
AWS_SECRET_ACCESS_KEY=tu_aws_secret_access_key
AWS_REGION=us-east-2
AWS_S3_BUCKET_NAME=startcompanies-blog

# ============================================
# Contabilidad — API keys por usuario (cifrado AES-256-GCM)
# ============================================
# Obligatoria para que los usuarios puedan guardar claves Anthropic/OpenAI en Ajustes.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# USER_SECRETS_ENCRYPTION_KEY=
# Opcionales (modelo por defecto alineado con validación al guardar la clave en Ajustes):
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_MODEL=gpt-4o-mini
# AI_BULK_MAX_PER_REQUEST=20

# ============================================
# Configuración de TypeORM
# ============================================
# IMPORTANTE: NUNCA usar true en producción
# false = usar migraciones (recomendado)
# true = sincronización automática (solo desarrollo)
SYNCHRONIZE=false
