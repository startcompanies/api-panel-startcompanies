{
  "name": "api-panel-startcompanies",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:generate": "ts-node --project tsconfig.json scripts/run-migration.ts generate",
    "migration:create": "ts-node --project tsconfig.json scripts/run-migration.ts create",
    "migration:run": "ts-node --project tsconfig.json scripts/run-migration.ts run",
    "migration:run:prod": "node dist/scripts/run-migration.js run",
    "migration:revert": "ts-node --project tsconfig.json scripts/run-migration.ts revert",
    "migration:revert:prod": "node dist/scripts/run-migration.js revert",
    "migration:show": "ts-node --project tsconfig.json scripts/run-migration.ts show",
    "migrate:blog-images": "ts-node --project tsconfig.json -r tsconfig-paths/register scripts/migrate-blog-images.ts",
    "sync:post-descriptions": "ts-node --project tsconfig.json -r tsconfig-paths/register scripts/sync-post-descriptions-from-migration-meta.ts",
    "fetch:post-titles": "ts-node --project tsconfig.json -r tsconfig-paths/register scripts/fetch-post-titles-from-businessenusa.ts",
    "db:wipe-panel": "node -r dotenv/config scripts/db-wipe-panel.cjs",
    "db:wipe-panel:prod": "NODE_ENV=production node -r dotenv/config scripts/db-wipe-panel.cjs",
    "posts:export": "ts-node --project tsconfig.json scripts/posts-portable.ts export",
    "posts:export:staging": "POSTS_EXPORT_PROFILE=staging POSTS_EXPORT_PARTIAL=1 ts-node --project tsconfig.json scripts/posts-portable.ts export -o scripts/posts-portable/posts_data.staging.sql",
    "posts:export:prod": "ts-node --project tsconfig.json scripts/posts-portable.ts export -o scripts/posts-portable/posts_data.prod.sql",
    "posts:import": "ts-node --project tsconfig.json scripts/posts-portable.ts import",
    "posts:import:staging": "ts-node --project tsconfig.json scripts/posts-portable.ts import -i scripts/posts-portable/posts_data.staging.sql",
    "posts:export:dist": "node dist/scripts/posts-portable.js export",
    "posts:import:prod": "node dist/scripts/posts-portable.js import -i scripts/posts-portable/posts_data.prod.sql",
    "wxr:post-categories-sql": "ts-node --project tsconfig.json scripts/wxr-to-post-categories-sql.ts",
    "wxr:post-categories-sql:run": "ts-node --project tsconfig.json scripts/wxr-to-post-categories-sql.ts scripts/posts.xml --execute"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.890.0",
    "@aws-sdk/lib-storage": "^3.890.0",
    "@aws-sdk/s3-request-presigner": "^3.890.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.17",
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.0.0",
    "@types/pdfkit": "^0.17.6",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.6.0",
    "rxjs": "^7.8.1",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "stripe": "^20.1.0",
    "typeorm": "^0.3.26"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
